# DreamWriter Environment Variables Template
# Copy this file to .env and fill in your API keys

# DeepSeek AI Configuration (Required for AI Chat feature)
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_API_MODEL=
DEEPSEEK_MAX_TOKENS=8192

# EvoLink Image Generation (Required for AI Image feature)
EVOLINK_API_TOKEN=

# VolcEngine Image Generation (Optional - Alternative image service)
VOLCENGINE_ACCESS_KEY=
VOLCENGINE_SECRET_KEY=
